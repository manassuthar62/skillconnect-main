rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone logged in can read; only owner can write
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Chat messages: only participants can read/write
    match /chats/{chatId} {
      allow read, write: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.participants);

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Posts: anyone logged in can read/like/comment; auth users can create
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Notifications: only owner can read; anyone logged in can write
    match /notifications/{uid}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null;
    }
  }
}
